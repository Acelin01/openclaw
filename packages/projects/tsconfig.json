{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"],
      "@uxin/iteration-lib": ["../iteration-lib/src/index.ts"],
      "@uxin/ui": ["../ui/src/index.ts"],
      "@uxin/artifact-ui": ["../artifact-ui/src/index.ts"],
      "@uxin/artifact-ui/*": ["../artifact-ui/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
