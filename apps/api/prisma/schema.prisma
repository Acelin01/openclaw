generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(uuid())
  email                   String                   @unique
  name                    String
  role                    UserRole                 @default(CUSTOMER)
  avatarUrl               String?
  phone                   String?
  isVerified              Boolean                  @default(false)
  password                String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  isSuspended             Boolean                  @default(false)
  departmentId            String?
  jobTitle                String?
  teamId                  String?
  chats                   Chat[]
  documents               Document[]
  ownedIterations         Iteration[]
  iterationActivities     IterationActivity[]
  iterationComments       IterationComment[]
  suggestions             Suggestion[]
  department              Department?              @relation(fields: [departmentId], references: [id])
  team                    Team?                    @relation(fields: [teamId], references: [id])
  UserAssociatedAgents    UserAssociatedAgents[]
  addresses               Address[]
  agents                  Agent[]
  aiConversations         AIConversation[]
  providerKeys            AIProviderKey[]
  apiClients              ApiClient[]
  interactionMetrics      ChatInteractionMetrics[]
  inquiries               Inquiry[]
  interviewsAsCandidate   Interview[]              @relation("Candidate")
  interviewsAsInterviewer Interview[]              @relation("Interviewer")
  invoices                Invoice[]
  mcpTools                MCPTool[]
  receivedMessages        Message[]                @relation("ReceivedMessages")
  sentMessages            Message[]                @relation("SentMessages")
  notifications           Notification[]
  positions               Position[]
  projectActivities       ProjectActivity[]
  approvedApprovals       ProjectApproval[]        @relation("ApprovalApprover")
  requestedApprovals      ProjectApproval[]        @relation("ApprovalRequester")
  assignedDefects         ProjectDefect[]          @relation("DefectAssignee")
  reportedDefects         ProjectDefect[]          @relation("DefectReporter")
  answeredQuestions       ProjectQnA[]             @relation("QnAAnswerer")
  askedQuestions          ProjectQnA[]             @relation("QnAAsker")
  assignedRequirements    ProjectRequirement[]     @relation("RequirementAssignee")
  reportedRequirements    ProjectRequirement[]     @relation("RequirementReporter")
  ownedRisks              ProjectRisk[]            @relation("RiskOwner")
  assignedTasks           ProjectTask[]            @relation("TaskAssignee")
  assignedMilestones      ProjectMilestone[]       @relation("MilestoneAssignee")
  projectMemberships      ProjectTeamMember[]
  projects                Project[]
  quotations              Quotation[]
  recruitmentApplications RecruitmentApplication[]
  recruitmentSettings     RecruitmentSetting?
  resumes                 Resume[]
  reviewsGiven            Review[]                 @relation("ReviewCustomer")
  reviewsReceived         Review[]                 @relation("ReviewProvider")
  schedules               Schedule[]
  sharedEmployee          SharedEmployee?
  usageLogs               SubscriptionUsageLog[]
  taxRecords              TaxRecord[]
  transactionsAsCustomer  Transaction[]            @relation("CustomerTransactions")
  transactionsAsProvider  Transaction[]            @relation("ProviderTransactions")
  userAIApps              UserAIApp[]              @relation("UserToAIApp")
  addedBy                 UserContact[]            @relation("ContactPerson")
  contacts                UserContact[]            @relation("UserContacts")
  events                  UserEvent[]
  sessions                UserSession[]
  subscriptions           UserSubscription[]
  userTasks               UserTask[]
  wallet                  Wallet?
  workerProfile           WorkerProfile?

  @@index([departmentId], map: "users_departmentId_fkey")
  @@index([teamId], map: "users_teamId_fkey")
  @@map("User")
}

model Wallet {
  id           String              @id @default(uuid())
  userId       String              @unique
  balance      Decimal             @default(0.00) @db.Decimal(10, 2)
  currency     String              @default("CNY")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  transactions WalletTransaction[]
  user         User                @relation(fields: [userId], references: [id])

  @@map("wallets")
}

model WalletTransaction {
  id          String                  @id @default(uuid())
  walletId    String
  amount      Decimal                 @db.Decimal(10, 2)
  type        WalletTransactionType
  category    String?
  description String?
  status      WalletTransactionStatus @default(COMPLETED)
  referenceId String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  wallet      Wallet                  @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@map("wallet_transactions")
}

model Invoice {
  id        String        @id @default(uuid())
  userId    String
  amount    Decimal       @db.Decimal(10, 2)
  status    InvoiceStatus @default(PENDING)
  title     String
  content   Json?
  issuedAt  DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("invoices")
}

model TaxRecord {
  id          String    @id @default(uuid())
  userId      String
  amount      Decimal   @db.Decimal(10, 2)
  taxType     String
  taxYear     Int
  status      TaxStatus @default(PENDING)
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("tax_records")
}

model Quotation {
  id                    String          @id @default(uuid())
  userId                String
  title                 String
  description           String
  category              String
  priceType             PriceType       @default(FIXED)
  priceAmount           Float?
  priceRangeMin         Float?
  priceRangeMax         Float?
  deliveryTime          String?
  includes              Json
  excludes              Json
  requirements          Json
  status                QuotationStatus @default(ACTIVE)
  aiGenerated           Boolean         @default(false)
  aiConversationId      String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  serviceId             String?
  templateId            String?
  service               WorkerService?  @relation("ServiceQuotations", fields: [serviceId], references: [id])
  template              Template?       @relation(fields: [templateId], references: [id])
  user                  User            @relation(fields: [userId], references: [id])
  transactions          Transaction[]
  primaryLinkedServices WorkerService[] @relation("PrimaryQuotation")

  @@index([userId])
  @@index([serviceId])
  @@index([category])
  @@index([status])
  @@index([createdAt])
  @@index([templateId])
  @@map("quotations")
}

model Inquiry {
  id               String        @id @default(uuid())
  userId           String
  title            String
  description      String
  category         String
  budgetMin        Float?
  budgetMax        Float?
  deadline         DateTime?
  requirements     Json
  deliverables     Json
  location         String?
  status           InquiryStatus @default(ACTIVE)
  aiGenerated      Boolean       @default(false)
  aiConversationId String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  templateId       String?
  template         Template?     @relation(fields: [templateId], references: [id])
  user             User          @relation(fields: [userId], references: [id])
  transactions     Transaction[]

  @@index([userId])
  @@index([category])
  @@index([status])
  @@index([budgetMin, budgetMax])
  @@index([templateId])
  @@map("inquiries")
}

model Transaction {
  id            String            @id @default(uuid())
  inquiryId     String?
  quotationId   String?
  customerId    String
  providerId    String
  amount        Float
  currency      String            @default("CNY")
  status        TransactionStatus @default(PENDING)
  paymentMethod String?
  paymentStatus PaymentStatus     @default(PENDING)
  contractData  Json?
  milestones    Json?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  projectId     String?
  reviews       Review[]
  customer      User              @relation("CustomerTransactions", fields: [customerId], references: [id])
  inquiry       Inquiry?          @relation(fields: [inquiryId], references: [id])
  project       Project?          @relation(fields: [projectId], references: [id])
  provider      User              @relation("ProviderTransactions", fields: [providerId], references: [id])
  quotation     Quotation?        @relation(fields: [quotationId], references: [id])

  @@index([customerId])
  @@index([providerId])
  @@index([status])
  @@index([createdAt])
  @@index([inquiryId], map: "transactions_inquiryId_fkey")
  @@index([projectId], map: "transactions_projectId_fkey")
  @@index([quotationId], map: "transactions_quotationId_fkey")
  @@map("transactions")
}

model AIConversation {
  id                 String                   @id @default(uuid())
  userId             String
  type               ConversationType
  context            Json?
  generatedData      Json?
  status             ConversationStatus       @default(ACTIVE)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  user               User                     @relation(fields: [userId], references: [id])
  interactionMetrics ChatInteractionMetrics[]
  messages           Message[]

  @@index([userId])
  @@map("ai_conversations")
}

model Task {
  id        String     @id @default(uuid())
  type      TaskType
  status    TaskStatus @default(PENDING)
  priority  Int        @default(0)
  payload   Json?
  result    Json?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("tasks")
}

model Message {
  id                 String                   @id @default(uuid())
  senderId           String?
  senderType         SenderType
  content            String
  messageType        MessageType              @default(TEXT)
  metadata           Json?
  createdAt          DateTime                 @default(now())
  aiConversationId   String?
  chatId             String?
  read               Boolean                  @default(false)
  readAt             DateTime?
  receiverId         String?
  interactionMetrics ChatInteractionMetrics[]
  aiConversation     AIConversation?          @relation(fields: [aiConversationId], references: [id])
  chat               Chat?                    @relation(fields: [chatId], references: [id])
  receiver           User?                    @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender             User?                    @relation("SentMessages", fields: [senderId], references: [id])

  @@index([chatId])
  @@index([senderId])
  @@index([receiverId])
  @@index([aiConversationId], map: "messages_aiConversationId_fkey")
  @@map("messages")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  content   String
  type      NotificationType
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  metadata  Json?
  user      User             @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@map("notifications")
}

model AIProviderKey {
  id        String   @id @default(uuid())
  userId    String?
  provider  String
  apiKey    String
  region    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId, provider, active])
  @@map("ai_provider_keys")
}

model SubscriptionPackage {
  id                 String             @id @default(uuid())
  name               String
  description        String
  type               PackageType
  price              Decimal            @db.Decimal(10, 2)
  currency           String             @default("CNY")
  durationDays       Int
  features           Json
  aiChatQuota        Int?
  priorityMatchQuota Int?
  isActive           Boolean            @default(true)
  sortOrder          Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  subscriptions      UserSubscription[]

  @@index([type])
  @@index([isActive])
  @@map("subscription_packages")
}

model UserSubscription {
  id                String                 @id @default(uuid())
  userId            String
  packageId         String
  status            SubscriptionStatus     @default(ACTIVE)
  startDate         DateTime
  endDate           DateTime
  aiChatUsed        Int                    @default(0)
  priorityMatchUsed Int                    @default(0)
  autoRenew         Boolean                @default(false)
  paymentStatus     PaymentStatus          @default(PENDING)
  paymentId         String?
  totalAmount       Decimal                @db.Decimal(10, 2)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  usageLogs         SubscriptionUsageLog[]
  package           SubscriptionPackage    @relation(fields: [packageId], references: [id])
  user              User                   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([endDate])
  @@index([packageId], map: "user_subscriptions_packageId_fkey")
  @@map("user_subscriptions")
}

model SubscriptionUsageLog {
  id               String           @id @default(uuid())
  userId           String
  subscriptionId   String
  usageType        UsageType
  usageDetail      Json?
  costAmount       Int              @default(1)
  remainingBalance Int?
  createdAt        DateTime         @default(now())
  subscription     UserSubscription @relation(fields: [subscriptionId], references: [id])
  user             User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([subscriptionId])
  @@index([createdAt])
  @@map("subscription_usage_logs")
}

model UserSession {
  id           String                   @id @default(uuid())
  userId       String?
  sessionId    String
  startedAt    DateTime                 @default(now())
  endedAt      DateTime?
  durationMs   Int?
  ipAddress    String?
  userAgent    String?
  device       String?
  browser      String?
  os           String?
  language     String?
  referrer     String?
  pageViews    Int                      @default(0)
  messagesSent Int                      @default(0)
  conversions  Int                      @default(0)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  interactions ChatInteractionMetrics[]
  events       UserEvent[]
  user         User?                    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("user_sessions")
}

model UserEvent {
  id         String        @id @default(uuid())
  userId     String?
  sessionId  String?
  eventType  UserEventType
  properties Json?
  timestamp  DateTime      @default(now())
  createdAt  DateTime      @default(now())
  session    UserSession?  @relation(fields: [sessionId], references: [id])
  user       User?         @relation(fields: [userId], references: [id])

  @@index([userId, eventType])
  @@index([sessionId])
  @@map("user_events")
}

model ChatInteractionMetrics {
  id             String          @id @default(uuid())
  userId         String?
  sessionId      String?
  conversationId String?
  messageId      String?
  role           ChatRole
  inputTokens    Int?
  outputTokens   Int?
  latencyMs      Int?
  sentimentScore Float?
  intent         String?
  success        Boolean         @default(true)
  createdAt      DateTime        @default(now())
  conversation   AIConversation? @relation(fields: [conversationId], references: [id])
  message        Message?        @relation(fields: [messageId], references: [id])
  session        UserSession?    @relation(fields: [sessionId], references: [id])
  user           User?           @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([sessionId])
  @@index([conversationId])
  @@index([messageId], map: "chat_interaction_metrics_messageId_fkey")
  @@map("chat_interaction_metrics")
}

model BusinessMetric {
  id        String       @id @default(uuid())
  metricKey String
  period    MetricPeriod
  value     Float
  dimension String?
  date      DateTime
  createdAt DateTime     @default(now())

  @@index([metricKey, date])
  @@map("business_metrics")
}

model Template {
  id            String         @id @default(uuid())
  name          String
  type          TemplateType
  schemaVersion String
  styleAssets   Json
  status        TemplateStatus @default(ACTIVE)
  usageCount    Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  inquiries     Inquiry[]
  quotations    Quotation[]
  shareLinks    ShareLink[]

  @@index([type, status])
  @@map("templates")
}

model ShareLink {
  id         String          @id @default(uuid())
  targetType ShareTargetType
  targetId   String
  templateId String?
  token      String          @unique
  url        String
  expireAt   DateTime?
  createdAt  DateTime        @default(now())
  template   Template?       @relation(fields: [templateId], references: [id])

  @@index([targetType, targetId])
  @@index([templateId], map: "share_links_templateId_fkey")
  @@map("share_links")
}

model WorkerProfile {
  id                  String                     @id @default(uuid())
  userId              String                     @unique
  title               String?
  bio                 String?                    @db.Text
  rating              Float                      @default(0)
  reviewCount         Int                        @default(0)
  location            String?
  languages           Json?
  skills              Json?
  badges              Json?
  hourlyRateAmount    Float?
  hourlyRateCurrency  String?                    @default("USD")
  hourlyRateUnit      String?                    @default("/小时")
  responseTimeValue   Int?
  responseTimeUnit    String?
  consultationEnabled Boolean                    @default(false)
  onlineStatus        Boolean                    @default(false)
  isVerified          Boolean                    @default(false)
  verifiedBy          String?
  verifiedDomains     Json?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  experiences         WorkerExperience[]
  portfolios          WorkerPortfolio[]
  user                User                       @relation(fields: [userId], references: [id])
  schedules           WorkerSchedule[]
  services            WorkerService[]
  certifications      WorkerSkillCertification[]

  @@map("worker_profiles")
}

model WorkerPortfolio {
  id          String        @id @default(uuid())
  workerId    String
  title       String
  description String?       @db.Text
  coverUrl    String?
  projectUrl  String?
  tags        Json?
  images      Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  worker      WorkerProfile @relation(fields: [workerId], references: [id])

  @@index([workerId])
  @@map("worker_portfolios")
}

model WorkerSkillCertification {
  id             String        @id @default(uuid())
  workerId       String
  skillName      String
  level          String?
  issuer         String?
  issueDate      DateTime?
  expiryDate     DateTime?
  certificateUrl String?
  isVerified     Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  worker         WorkerProfile @relation(fields: [workerId], references: [id])

  @@index([workerId])
  @@map("worker_skill_certifications")
}

model WorkerService {
  id            String                  @id @default(uuid())
  workerId      String
  quotationId   String?
  title         String
  description   String                  @db.Text
  coverImageUrl String?
  priceAmount   Float
  priceCurrency String                  @default("USD")
  unit          String?
  deliveryTime  String?
  category      String?
  status        worker_services_status?
  rating        Float?
  reviewCount   Int?
  tags          Json?
  features      Json?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  documents     Document[]
  quotations    Quotation[]             @relation("ServiceQuotations")
  reviews       Review[]
  faqs          ServiceFAQ[]
  packages      ServicePackage[]
  quotation     Quotation?              @relation("PrimaryQuotation", fields: [quotationId], references: [id])
  worker        WorkerProfile           @relation(fields: [workerId], references: [id])

  @@index([workerId])
  @@index([quotationId])
  @@index([rating])
  @@index([createdAt])
  @@map("worker_services")
}

model ServicePackage {
  id        String               @id @default(uuid())
  serviceId String
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  plans     ServicePackagePlan[]
  service   WorkerService        @relation(fields: [serviceId], references: [id])

  @@index([serviceId])
  @@map("service_packages")
}

model ServicePackagePlan {
  id            String         @id @default(uuid())
  packageId     String
  tier          PackageTier
  name          String
  priceAmount   Float
  priceCurrency String         @default("USD")
  deliveryTime  String?
  features      Json
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  package       ServicePackage @relation(fields: [packageId], references: [id])

  @@index([packageId])
  @@index([tier, priceAmount])
  @@map("service_package_plans")
}

model WorkerExperience {
  id             String        @id @default(uuid())
  workerId       String
  companyName    String
  companyLogoUrl String?
  roles          Json
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  worker         WorkerProfile @relation(fields: [workerId], references: [id])

  @@index([workerId])
  @@map("worker_experiences")
}

model WorkerSchedule {
  id          String        @id @default(uuid())
  workerId    String
  dayOfWeek   Int           @default(1)
  startTime   String
  endTime     String
  isAvailable Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  worker      WorkerProfile @relation(fields: [workerId], references: [id])

  @@index([workerId])
  @@map("worker_schedules")
}

model Review {
  id            String         @id @default(uuid())
  transactionId String?
  serviceId     String?
  providerId    String
  customerId    String
  rating        Int
  aspects       Json?
  title         String?
  content       String         @db.Text
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  customer      User           @relation("ReviewCustomer", fields: [customerId], references: [id])
  provider      User           @relation("ReviewProvider", fields: [providerId], references: [id])
  service       WorkerService? @relation(fields: [serviceId], references: [id])
  transaction   Transaction?   @relation(fields: [transactionId], references: [id])

  @@index([providerId])
  @@index([serviceId])
  @@index([createdAt])
  @@index([customerId], map: "reviews_customerId_fkey")
  @@index([transactionId], map: "reviews_transactionId_fkey")
  @@map("reviews")
}

model ServiceFAQ {
  id        String        @id @default(uuid())
  serviceId String
  question  String
  answer    String        @db.Text
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  service   WorkerService @relation(fields: [serviceId], references: [id])

  @@index([serviceId])
  @@map("service_faqs")
}

model Chat {
  id             String         @id @default(uuid())
  createdAt      DateTime       @default(now())
  title          String         @db.Text
  userId         String
  visibility     ChatVisibility @default(private)
  isPinned       Boolean        @default(false)
  lastContext    Json?
  projectId      String?
  agentId        String?
  agent          Agent?         @relation(fields: [agentId], references: [id])
  project        Project?       @relation(fields: [projectId], references: [id])
  user           User           @relation(fields: [userId], references: [id])
  documents      Document[]
  messages       ChatMessage[]
  streams        Stream[]
  votes          Vote[]
  AgentToChat    AgentToChat[]
  legacyMessages Message[]

  @@index([userId])
  @@index([projectId], map: "Chat_projectId_fkey")
  @@index([userId, createdAt], map: "idx_userId_createdAt")
  @@index([userId, createdAt], map: "user_createdAt_idx")
  @@index([agentId], map: "Chat_agentId_fkey")
  @@map("Chat")
}

model ChatMessage {
  id           String     @id @default(uuid())
  chatId       String
  role         String     @db.VarChar(32)
  parts        Json
  attachments  Json
  createdAt    DateTime
  agentId      String?
  authorAvatar String?    @db.Text
  authorName   String?    @db.VarChar(255)
  content      String?    @db.Text
  userId       String?    @db.VarChar(36)
  documents    Document[]
  agent        Agent?     @relation(fields: [agentId], references: [id])
  chat         Chat       @relation(fields: [chatId], references: [id], onDelete: Cascade)
  votes        Vote[]

  @@index([chatId])
  @@index([agentId])
  @@index([chatId, createdAt], map: "idx_chatId_createdAt")
  @@index([chatId, createdAt], map: "chat_createdAt_idx")
  @@map("Message_v2")
}

model Document {
  id             String          @default(uuid())
  createdAt      DateTime
  title          String          @db.Text
  content        String?         @db.Text
  kind           Document_kind?  @default(quote)
  userId         String
  chatId         String?
  projectId      String?
  serviceId      String?
  agentId        String?
  messageId      String?
  status         DocumentStatus  @default(PENDING)
  visibility     ChatVisibility  @default(private)
  agent          Agent?          @relation(fields: [agentId], references: [id])
  chat           Chat?           @relation(fields: [chatId], references: [id])
  message        ChatMessage?    @relation(fields: [messageId], references: [id])
  project        Project?        @relation(fields: [projectId], references: [id])
  service        WorkerService?  @relation(fields: [serviceId], references: [id])
  user           User            @relation(fields: [userId], references: [id])
  suggestions    Suggestion[]
  agentDocuments AgentDocument[]

  @@id([id, createdAt])
  @@index([userId])
  @@index([chatId], map: "Document_chatId_fkey")
  @@index([messageId])
  @@index([projectId], map: "Document_projectId_fkey")
  @@index([serviceId], map: "Document_serviceId_fkey")
  @@index([userId, kind, createdAt], map: "idx_userId_kind_createdAt")
  @@index([userId, kind, createdAt], map: "user_kind_createdAt_idx")
  @@index([agentId], map: "Document_agentId_fkey")
  @@map("Document")
}

model Suggestion {
  id                String   @id @default(uuid())
  documentId        String
  documentCreatedAt DateTime
