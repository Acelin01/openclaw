  userId               String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  avatar               String?                @db.Text
  departmentId         String?
  chats                Chat[]
  documents            Document[]
  messages             ChatMessage[]
  AIAppAgents          AIAppAgents[]
  AgentToChat          AgentToChat[]
  UserAssociatedAgents UserAssociatedAgents[]
  agentDocuments       AgentDocument[]
  department           Department?            @relation(fields: [departmentId], references: [id])
  user                 User?                  @relation(fields: [userId], references: [id])
  teamMemberships      ProjectTeamMember[]
  contacts             UserContact[]
  agents_A             Agent[]                @relation("AgentSkills")
  agents_B             Agent[]                @relation("AgentSkills")
  projects             Project[]              @relation("AgentToProject")
  requirements         ProjectRequirement[]   @relation("AgentToProjectRequirement")
  tasks                ProjectTask[]          @relation("AgentToProjectTask")
  mcpTools             MCPTool[]              @relation("AgentTools")

  @@index([userId])
  @@index([departmentId], map: "agents_departmentId_fkey")
  @@map("agents")
}

model MCPTool {
  id           String    @id @default(uuid())
  name         String    @db.VarChar(50)
  description  String?   @db.Text
  avatar       String?   @db.Text
  publisher    String?   @db.VarChar(100)
  skills       Json?
  rating       Float     @default(0)
  isBuiltIn    Boolean   @default(true)
  isAppOutput  Boolean   @default(false)
  creatorId    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  config       Json?
  endpoint     String?   @db.Text
  type         String    @default("REST")
  capabilities Json?
  creator      User?     @relation(fields: [creatorId], references: [id])
  skillList    Skill[]
  aiApps       AIApp[]   @relation("AIAppTools")
  agents       Agent[]   @relation("AgentTools")
  mcp_tools_A  MCPTool[] @relation("ToolRelations")
  mcp_tools_B  MCPTool[] @relation("ToolRelations")

  @@index([creatorId])
  @@map("mcp_tools")
}

model ApiClient {
  id                  String        @id @default(uuid())
  ownerUserId         String?
  name                String
  description         String?
  status              String        @default("ACTIVE")
  rateLimitPerMin     Int           @default(60)
  defaultProjectId    String?
  defaultTeamId       String?
  toolAllowlist       Json?
  permissionAllowlist Json?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  owner               User?         @relation(fields: [ownerUserId], references: [id])
  tokens              ApiToken[]
  usageLogs           ApiUsageLog[]

  @@index([ownerUserId])
  @@index([status])
  @@map("api_clients")
}

model ApiToken {
  id         String        @id @default(uuid())
  clientId   String
  name       String
  tokenHash  String        @db.VarChar(128)
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime      @default(now())
  client     ApiClient     @relation(fields: [clientId], references: [id])
  usageLogs  ApiUsageLog[]

  @@index([clientId])
  @@index([tokenHash])
  @@map("api_tokens")
}

model ApiUsageLog {
  id         String    @id @default(uuid())
  clientId   String
  tokenId    String?
  tool       String?
  endpoint   String
  statusCode Int
  latencyMs  Int?
  createdAt  DateTime  @default(now())
  client     ApiClient @relation(fields: [clientId], references: [id])
  token      ApiToken? @relation(fields: [tokenId], references: [id])

  @@index([clientId, createdAt])
  @@index([tokenId])
  @@map("api_usage_logs")
}

model Skill {
  id          String   @id @default(uuid())
  mcpToolId   String
  name        String
  description String?  @db.Text
  parameters  Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  mcpTool     MCPTool  @relation(fields: [mcpToolId], references: [id], onDelete: Cascade)

  @@index([mcpToolId])
  @@map("skills")
}

model drizzle_migrations {
  id         BigInt  @id @unique(map: "id") @default(autoincrement()) @db.UnsignedBigInt
  hash       String  @db.Text
  created_at BigInt?

  @@map("__drizzle_migrations")
}

model Team {
  id          String       @id @default(uuid())
  name        String
  description String?      @db.Text
  avatarUrl   String?
  createdAt   DateTime?    @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  users       User[]
  departments Department[]
  positions   Position[]
  projects    Project[]

  @@map("teams")
}

model AgentToChat {
  A      String
  B      String
  agents Agent  @relation(fields: [A], references: [id], onDelete: Cascade)
  Chat   Chat   @relation(fields: [B], references: [id], onDelete: Cascade)

  @@unique([A, B], map: "_AgentToChat_AB_unique")
  @@index([B], map: "_AgentToChat_B_index")
  @@map("_AgentToChat")
}

model Iteration {
  id              String                @id @default(uuid())
  projectId       String?
  collaborationId String?
  name            String
  description     String?               @db.Text
  goals           Json?
  status          String                @default("PLANNING")
  startDate       DateTime
  endDate         DateTime
  ownerId         String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  collaboration   ProjectCollaboration? @relation(fields: [collaborationId], references: [id], onDelete: Cascade)
  owner           User                  @relation(fields: [ownerId], references: [id])
  project         Project?              @relation(fields: [projectId], references: [id])
  activities      IterationActivity[]
  comments        IterationComment[]
  defects         ProjectDefect[]
  requirements    ProjectRequirement[]
  tasks           ProjectTask[]

  @@index([projectId])
  @@index([collaborationId])
  @@index([ownerId])
  @@index([status])
}

model IterationComment {
  id          String             @id @default(uuid())
  content     String             @db.Text
  iterationId String
  userId      String
  parentId    String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  iteration   Iteration          @relation(fields: [iterationId], references: [id], onDelete: Cascade)
  parent      IterationComment?  @relation("IterationCommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies     IterationComment[] @relation("IterationCommentReplies")
  user        User               @relation(fields: [userId], references: [id])

  @@index([iterationId])
  @@index([userId])
  @@index([parentId], map: "IterationComment_parentId_fkey")
}

model IterationActivity {
  id          String    @id @default(uuid())
  action      String
  content     String?   @db.Text
  iterationId String
  userId      String
  createdAt   DateTime  @default(now())
  iteration   Iteration @relation(fields: [iterationId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])

  @@index([iterationId])
  @@index([userId])
}

model AIApp {
  id             String                 @id @default(uuid())
  name           String                 @db.VarChar(50)
  description    String?                @db.Text
  icon           String?                @db.Text
  status         String                 @default("PUBLISHED")
  type           String                 @default("TOOL")
  category       String?                @db.VarChar(50)
  isSystem       Boolean                @default(false)
  config         Json?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  AIAppAgents    AIAppAgents[]
  collaborations ProjectCollaboration[] @relation("AIAppCollaborations")
  projects       Project[]              @relation("AIAppProjects")
  userApps       UserAIApp[]            @relation("AIAppToUser")
  mcpTools       MCPTool[]              @relation("AIAppTools")

  @@map("ai_apps")
}

model UserAIApp {
  id        String   @id @default(uuid())
  userId    String
  appId     String
  isDefault Boolean  @default(false)
  addedAt   DateTime @default(now())
  app       AIApp    @relation("AIAppToUser", fields: [appId], references: [id])
  user      User     @relation("UserToAIApp", fields: [userId], references: [id])

  @@unique([userId, appId])
  @@index([userId])
  @@index([appId])
  @@map("user_ai_apps")
}

model AIAppAgents {
  A       String
  B       String
  ai_apps AIApp  @relation(fields: [A], references: [id], onDelete: Cascade)
  agents  Agent  @relation(fields: [B], references: [id], onDelete: Cascade)

  @@unique([A, B], map: "_AIAppAgents_AB_unique")
  @@index([B], map: "_AIAppAgents_B_index")
  @@map("_AIAppAgents")
}

model UserAssociatedAgents {
  A      String
  B      String
  agents Agent  @relation(fields: [A], references: [id], onDelete: Cascade)
  User   User   @relation(fields: [B], references: [id], onDelete: Cascade)

  @@unique([A, B], map: "_UserAssociatedAgents_AB_unique")
  @@index([B], map: "_UserAssociatedAgents_B_index")
  @@map("_UserAssociatedAgents")
}

