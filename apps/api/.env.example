# ════════════════════════════════════════
# ChatLite API 环境配置示例
# ════════════════════════════════════════

# 服务器配置
PORT=8000
NODE_ENV=development

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/chatlite

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ════════════════════════════════════════
# 短信服务配置 (二选一)
# ════════════════════════════════════════

# 阿里云短信
ALIYUN_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
ALIYUN_SMS_SIGN_NAME=技能共享平台
ALIYUN_SMS_TEMPLATE_CODE=SMS_123456789

# 腾讯云短信
TENCENT_ACCESS_KEY_ID=your-tencent-access-key-id
TENCENT_ACCESS_KEY_SECRET=your-tencent-access-key-secret
TENCENT_SMS_SIGN_NAME=技能共享平台
TENCENT_SMS_TEMPLATE_CODE=123456

# ════════════════════════════════════════
# OAuth 配置
# ════════════════════════════════════════

# 微信开放平台
WECHAT_APP_ID=wx_xxxxxxxxxxxxxxxx
WECHAT_APP_SECRET=your-wechat-app-secret
WECHAT_REDIRECT_URI=http://localhost:3002/auth/callback/wechat

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:3002/auth/callback/github

# ════════════════════════════════════════
# 文件上传配置
# ════════════════════════════════════════

# 本地存储
UPLOAD_PROVIDER=local
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# 阿里云 OSS (可选)
# UPLOAD_PROVIDER=aliyun-oss
# ALIYUN_OSS_REGION=oss-cn-hangzhou
# ALIYUN_OSS_ACCESS_KEY_ID=your-oss-access-key-id
# ALIYUN_OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
# ALIYUN_OSS_BUCKET=your-bucket-name

# ════════════════════════════════════════
# 邮件服务配置 (可选)
# ════════════════════════════════════════

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password
SMTP_SECURE=false
